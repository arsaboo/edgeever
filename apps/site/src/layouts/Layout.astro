---
import { SEO } from "astro-seo";
import Footer from "@/components/footer.astro";
import Navbar from "@/components/navbar/navbar.astro";
import "@fontsource-variable/inter/index.css";
import "@fontsource-variable/bricolage-grotesque";
import "../styles/global.css";

export interface Props {
  title: string;
  description?: string;
  image?: string;
  imageAlt?: string;
  openGraphType?: "website" | "article";
  articlePublishedTime?: string;
  articleModifiedTime?: string;
  articleAuthor?: string;
  articleSection?: string;
  articleTags?: string[];
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
  noindex?: boolean;
}

const canonicalURL = new URL(Astro.url.pathname, Astro.site).toString();

const defaultDescription =
  "EdgeEver 是一个开源、自托管、Cloudflare-native 的现代笔记工作区。保留经典印象笔记的三栏体验，支持富文本、无限嵌套，原生支持 MCP 对 AI Agent 极度友好，个人托管接近零成本。";

const {
  title,
  description = defaultDescription,
  image = "/opengraph.jpg",
  imageAlt = "EdgeEver 笔记应用截图",
  openGraphType = "website",
  articlePublishedTime,
  articleModifiedTime,
  articleAuthor,
  articleSection,
  articleTags,
  jsonLd,
  noindex = false,
} = Astro.props;

const resolvedImageWithDomain = new URL(image, Astro.site).toString();

const makeTitle = title
  ? title + " | " + "EdgeEver"
  : "EdgeEver - 基于 Cloudflare 全家桶自托管的免费开源『印象笔记』";

const faviconVersion = "edgeever-brand-20260703";
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href={`/favicon.svg?v=${faviconVersion}`} />
    <meta name="theme-color" content="#f8fafc" />
    <meta name="generator" content={Astro.generator} />

    <!-- <link rel="preload" as="image" href={src} alt="Hero" /> -->
    <SEO
      title={makeTitle}
      description={description}
      canonical={canonicalURL}
      noindex={noindex}
      twitter={{
        creator: "@msh01",
        site: "@edgeever",
        card: "summary_large_image",
        title: makeTitle,
        description,
        image: resolvedImageWithDomain,
        imageAlt,
      }}
      openGraph={{
        basic: {
          url: canonicalURL,
          type: openGraphType,
          title: makeTitle,
          image: resolvedImageWithDomain,
        },
        optional: {
          description,
          locale: "zh_CN",
          siteName: "EdgeEver",
        },
        image: {
          alt: imageAlt,
        },
        article:
          openGraphType === "article"
            ? {
                publishedTime: articlePublishedTime,
                modifiedTime: articleModifiedTime,
                authors: articleAuthor ? [articleAuthor] : undefined,
                section: articleSection,
                tags: articleTags,
              }
            : undefined,
      }}
    />
    {
      jsonLd && (
        <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
      )
    }
  </head>
  <body>
    <Navbar />
    <slot />
    <Footer />
    <style is:global>
      /* Improve Page speed */
      /* https://css-tricks.com/almanac/properties/c/content-visibility/ */
      img {
        content-visibility: auto;
      }
    </style>
  </body>
</html>
